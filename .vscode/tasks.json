{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run Home Assistant",
      "type": "shell",
      "command": "python3 -m homeassistant --config /config --debug",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    },
    {
      "label": "Restart Home Assistant",
      "type": "shell",
      "command": "pkill -f homeassistant && sleep 2 && python3 -m homeassistant --config /config --debug &",
      "problemMatcher": []
    },
    {
      "label": "Check Config",
      "type": "shell",
      "command": "python3 -m homeassistant --config /config --script check_config",
      "problemMatcher": []
    },
    {
      "label": "Run Tests",
      "type": "shell",
      "command": "pytest custom_components/my_verisure/tests/ -v",
      "problemMatcher": [],
      "group": {
        "kind": "test",
        "isDefault": true
      }
    },
    {
      "label": "Lint: Pylint",
      "type": "shell",
      "command": "pylint custom_components/my_verisure",
      "problemMatcher": []
    },
    {
      "label": "Format: Black",
      "type": "shell",
      "command": "black custom_components/my_verisure",
      "problemMatcher": []
    },
    {
      "label": "Type Check: MyPy",
      "type": "shell",
      "command": "mypy custom_components/my_verisure",
      "problemMatcher": []
    }
  ]
}
