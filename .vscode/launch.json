{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Home Assistant (DevContainer)",
      "type": "python",
      "request": "launch",
      "module": "homeassistant",
      "justMyCode": false,
      "args": [
        "--debug",
        "-c",
        "/config"
      ],
      "console": "integratedTerminal",
      "env": {
        "PYTHONPATH": "/workspaces/core"
      }
    },
    {
      "name": "Python: Current File",
      "type": "python",
      "request": "launch",
      "program": "${file}",
      "console": "integratedTerminal",
      "justMyCode": false
    },
    {
      "name": "Python: Pytest Current File",
      "type": "python",
      "request": "launch",
      "module": "pytest",
      "args": [
        "${file}",
        "-v"
      ],
      "console": "integratedTerminal",
      "justMyCode": false
    }
  ]
}
