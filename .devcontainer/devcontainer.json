{
  "name": "My Verisure Development",
  "image": "ghcr.io/home-assistant/home-assistant:stable",
  "appPort": [
    "7123:8123"
  ],
  "postCreateCommand": "pip install --upgrade pip && pip install pytest pytest-asyncio pytest-homeassistant-custom-component",
  "runArgs": [
    "--privileged"
  ],
  "mounts": [
    "type=bind,source=${localWorkspaceFolder}/custom_components/my_verisure,target=/config/custom_components/my_verisure",
    "type=bind,source=${localWorkspaceFolder}/.devcontainer/configuration.yaml,target=/config/configuration.yaml",
    "type=bind,source=${localWorkspaceFolder}/.devcontainer/automations.yaml,target=/config/automations.yaml",
    "type=bind,source=${localWorkspaceFolder}/.devcontainer/scripts.yaml,target=/config/scripts.yaml",
    "type=bind,source=${localWorkspaceFolder}/.devcontainer/scenes.yaml,target=/config/scenes.yaml"
  ],
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-python.black-formatter",
        "visualstudioexptteam.vscodeintellicode",
        "redhat.vscode-yaml",
        "esbenp.prettier-vscode"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/bin/python3",
        "python.linting.enabled": true,
        "python.linting.pylintEnabled": false,
        "python.formatting.provider": "black",
        "editor.formatOnSave": true,
        "python.testing.pytestEnabled": true,
        "files.eol": "\n",
        "editor.tabSize": 4,
        "terminal.integrated.defaultProfile.linux": "bash"
      }
    }
  },
  "forwardPorts": [
    7123
  ],
  "portsAttributes": {
    "7123": {
      "label": "Home Assistant",
      "onAutoForward": "notify"
    }
  }
}
